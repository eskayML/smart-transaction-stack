# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_WS_URL=wss://api.devnet.solana.com
COMMITMENT=confirmed

# Jito Block Engine (mainnet)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_WS_URL=ws://mainnet.block-engine.jito.wtf

# Yellowstone gRPC (get from SolInfra after credits provisioned)
YELLOWSTONE_GRPC_ENDPOINT=
YELLOWSTONE_GRPC_XTOKEN=

# AI Agent (OpenAI-compatible)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Wallet (comma-separated uint8 array of your Solana private key)
WALLET_PRIVATE_KEY=

# Demo config
BUNDLE_COUNT=12
REQUIRED_FAILURES=3
SIMULATE_BLOCKHASH_EXPIRY=true
